{
  "manifest_version": 3,
  "name": "Guardião NBR 17225",
  "version": "1.0.1",
  "description": "Verificador profissional de acessibilidade web conforme ABNT NBR 17225:2025",
  "permissions": ["storage", "activeTab", "scripting"],
  "web_accessible_resources": [
    {
      "resources": ["content-bootstrap.js", "content.js", "rules.js", "i18n.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
